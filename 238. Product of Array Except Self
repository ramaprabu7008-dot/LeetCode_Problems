class Solution {
    public int[] productExceptSelf(int[] nums) {
    int n=nums.length;
        int []arr=new int[n];
        int []p=new int[n];
        p[0]=nums[0];
        for(int i=1;i<n;i++)
        p[i]=p[i-1]*nums[i];
        int []su=new int[n];
        su[n-1]=nums[n-1];
        for(int i=n-2;i>=0;i--)
        su[i]=su[i+1]*nums[i];
        for(int i=0;i<n;i++)
        {int l=(i==0)?1:p[i-1];
        int r=(i==n-1)?1:su[i+1];
        arr[i]=l*r;
        }
        return arr;    
    }
}
